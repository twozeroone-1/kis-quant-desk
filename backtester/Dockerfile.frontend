FROM node:22-alpine AS deps

WORKDIR /app
COPY backtester/frontend/package*.json ./
RUN npm ci

FROM node:22-alpine AS builder

WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY backtester/frontend/ ./
RUN npm run build

FROM node:22-alpine

ENV NODE_ENV=production

WORKDIR /app
COPY --from=builder /app ./

EXPOSE 3001

CMD ["npm", "run", "start"]
