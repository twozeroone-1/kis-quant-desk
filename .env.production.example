# Copy to .env.production before deployment.
CADDY_AUTH_USER=your_username
# Keep the hash single-quoted so Compose passes `$` through literally.
CADDY_AUTH_HASH='$2a$14$replace_with_caddy_hash_password_output'

# Docker Desktop bind mounts on the Windows host.
KIS_CONFIG_DIR=C:/kis-stack/config
KIS_LOG_DIR=C:/kis-stack/logs

# Bind Caddy to the Windows Tailscale IPv4 address for tailnet-only access.
CADDY_BIND_IP=100.x.y.z

# Order audit logging.
AUDIT_LOG_DIR=/var/log/kis/orders
AUDIT_LOG_RETENTION_DAYS=365
